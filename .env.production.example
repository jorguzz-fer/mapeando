# ───────────────────────────────────────────────────────────────────
# Mapeando — variáveis de PRODUÇÃO (Coolify).
# Cole estas chaves no painel do Coolify (Environment Variables) do recurso
# Docker Compose. NUNCA comite valores reais.
# ───────────────────────────────────────────────────────────────────

# Domínio público do app (o serviço `web`). Usado em CORS.
WEB_ORIGIN=https://mapeando.seudominio.com.br

# Senhas do banco — gere valores fortes (ex.: openssl rand -hex 24)
POSTGRES_ADMIN_PASSWORD=troque-senha-admin-forte
APP_DB_PASSWORD=troque-senha-app-forte

# Segredo da sessão (cookie assinado) — gere: openssl rand -hex 32
SESSION_SECRET=troque-por-32-bytes-aleatorios

# IA — Anthropic / Claude (necessária só p/ chat e Missão)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_CHAT=claude-sonnet-4-6
ANTHROPIC_MODEL_MISSION=claude-opus-4-8

# Geo (opcionais). Sem OSRM, a rota usa fallback aproximado.
OSRM_URL=
NOMINATIM_URL=
NOMINATIM_USER_AGENT=Mapeando/1.0 (contato: fer.jorge@gmail.com)
