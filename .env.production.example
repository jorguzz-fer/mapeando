# ───────────────────────────────────────────────────────────────────
# Mapeando — variáveis de PRODUÇÃO (Coolify, deploy por Dockerfile único).
# Cole no painel do Coolify → sua Application → Environment Variables.
# O front é servido pela própria API (mesmo container). NUNCA comite valores reais.
# ───────────────────────────────────────────────────────────────────

NODE_ENV=production
API_PORT=3333

# Domínio público do app (o mesmo da Application). Usado em CORS.
WEB_ORIGIN=https://mapeando.seudominio.com.br

# Banco (recurso PostgreSQL do Coolify com imagem postgis/postgis:16-3.4).
# DATABASE_URL  = role da APLICAÇÃO (mapeando, NÃO superuser) → RLS ativo.
# DATABASE_ADMIN_URL = superuser do Coolify (migrations/import/provisionamento).
# Use o host INTERNO do recurso (ex.: <nome-do-servico>:5432).
DATABASE_URL=postgresql://mapeando:SENHA_APP@postgres:5432/mapeando
DATABASE_ADMIN_URL=postgresql://postgres:SENHA_SUPER@postgres:5432/mapeando

# Redis (recurso Redis do Coolify) — host interno.
REDIS_URL=redis://redis:6379

# Sessão (cookie assinado) — gere: openssl rand -hex 32
SESSION_SECRET=troque-por-32-bytes-aleatorios

# IA — Anthropic / Claude (necessária só p/ chat e Missão)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_CHAT=claude-sonnet-4-6
ANTHROPIC_MODEL_MISSION=claude-opus-4-8

# Geo (opcionais). Sem OSRM, a rota usa fallback aproximado.
OSRM_URL=
NOMINATIM_URL=
NOMINATIM_USER_AGENT=Mapeando/1.0 (contato: fer.jorge@gmail.com)
