# ───────────────────────────────────────────────────────────────────
# Mapeando — exemplo de configuração (12-factor). Copie para .env e ajuste.
# NUNCA comite segredos reais. (Blueprint §5)
# ───────────────────────────────────────────────────────────────────

# Banco (PostgreSQL + PostGIS)
DATABASE_URL=postgresql://mapeando:mapeando@localhost:5432/mapeando
# Role administrativo (BYPASSRLS) usado por scripts de provisionamento/import
# (criar tenant, carga em massa). NUNCA é usado pelo servidor da aplicação.
DATABASE_ADMIN_URL=postgresql://mapeando_admin:mapeando_admin@localhost:5432/mapeando

# Redis (cache / filas)
REDIS_URL=redis://localhost:6379

# Sessão (cookie httpOnly assinado) — gere um valor aleatório forte
SESSION_SECRET=troque-este-segredo-em-producao

# IA — Anthropic / Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_CHAT=claude-sonnet-4-6
ANTHROPIC_MODEL_MISSION=claude-opus-4-8

# Geo / mapas (OpenStreetMap)
# OSRM: rota e TSP. Use o demo público SÓ em dev; produção = self-host (infra/).
OSRM_URL=http://localhost:5000
# Nominatim: geocodificação. Vazio => usa o público (limite 1 req/s).
NOMINATIM_URL=
# User-Agent exigido pela política de uso do Nominatim público.
NOMINATIM_USER_AGENT=Mapeando/0.1 (contato: fer.jorge@gmail.com)

# API
API_PORT=3333
# Origem do front para CORS/cookies
WEB_ORIGIN=http://localhost:5173

# Front (Vite) — prefixo VITE_ é exposto ao browser
VITE_API_URL=http://localhost:3333
VITE_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json
